<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>CK Product Carousel</masterLabel>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property name="sectionTitle" type="String" default="Signature Series" label="Section Title" />
            <property name="sectionSubtitle" type="String" default="Experience our most coveted drops." label="Section Subtitle" />
            <property name="maxProducts" type="Integer" default="10" label="Max Products" />
            <property name="visibleCount" type="Integer" default="4" label="Products Visible" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>